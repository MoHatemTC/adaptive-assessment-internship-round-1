# Keep the build context small and free of host-only / secret files.
# Mirrors the root .gitignore for the backend.

# ── Python ──
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Packaging / build artifacts
*.egg-info/
dist/
build/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/

# Celery
celerybeat-schedule
celerybeat.pid

# ── Env (never bake secrets into the image; provided via env_file at runtime) ──
.env
.env.local
.env.*.local

# ── VCS / tooling ──
.git
.gitignore
.dockerignore
Dockerfile

# ── OS / IDE ──
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ── Logs ──
*.log
*.pid
