DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/masaar
REDIS_URL=redis://redis:6379/0
LITELLM_API_KEY=
LITELLM_BASE_URL=
# Sprint.ai proxy example: openai/FW-Kimi-K2.6
LITELLM_MODEL=gpt-4o
TRANSCRIPTION_MODEL=azure/whisper
LITELLM_VISION_MODEL=
# Qdrant Cloud (team dev/staging/prod). Leave empty only for CI unit tests — memory retrieval will no-op.
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=platform_memory
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
E2B_API_KEY=
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
FACE_PROVIDER=auto
# auto prefers VLM when LITELLM_API_KEY is set, else Hugging Face ArcFace, then Azure
# Set explicitly: vlm | huggingface | azure
FACE_API_ENDPOINT=
FACE_API_KEY=
HF_TOKEN=
HF_FACE_MODEL_REPO=onnx-community/arcface-onnx
HF_FACE_MODEL_FILE=arcface.onnx
FACE_MATCH_THRESHOLD=0.7
PROCTORING_HIGH_SEVERITY_THRESHOLD=3
# Seconds with zero people in frame before candidate_absent is logged (WP-4).
PROCTORING_CANDIDATE_ABSENCE_GRACE_SECONDS=5
CODE_ASYNC_GRADING=true
