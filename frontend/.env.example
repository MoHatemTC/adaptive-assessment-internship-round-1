# Leave empty so the browser uses same-origin /api (nginx or Next.js rewrites).
# Only set this when the API is on another origin with CORS enabled.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Next.js server-side proxy target (Docker Compose sets http://backend:8000)
BACKEND_URL=http://localhost:8000
