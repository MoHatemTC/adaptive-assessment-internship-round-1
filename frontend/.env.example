# Leave empty so the browser uses same-origin /api (nginx or Next.js rewrites).
# Only set this when the API is on another origin with CORS enabled.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Set after running backend/scripts/seed_demo_assessment.py
NEXT_PUBLIC_DEMO_ASSESSMENT_ID=a1b2c3d4-e5f6-4789-a012-3456789abcde
# Camera VLM poll interval in ms (WP-4, max 2000). Default 1500.
NEXT_PUBLIC_PROCTORING_CAMERA_INTERVAL_MS=1500
# Next.js server-side proxy target (Docker Compose sets http://backend:8000)
BACKEND_URL=http://localhost:8000
