DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/masaar
REDIS_URL=redis://redis:6379/0
LITELLM_API_KEY=
LITELLM_BASE_URL=
# Sprint.ai proxy example: openai/FW-Kimi-K2.6 (multimodal — works for diagram VLM grading)
LITELLM_MODEL=gpt-4o
TRANSCRIPTION_MODEL=whisper
LITELLM_VISION_MODEL=
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
RESEND_API_KEY=
RESEND_FROM=Masaar <reports@sprints.ai>
ADMIN_REPORT_EMAIL=
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CELERY_PIPELINES=false
E2B_API_KEY=
SECRET_KEY=change-me-in-production
# Admin JWT lifetime in minutes (default 30; use 480 for long local dev sessions)
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
FACE_PROVIDER=auto
# auto prefers VLM when LITELLM_API_KEY is set, else Hugging Face ArcFace, then Azure
# Set explicitly: vlm | huggingface | azure
FACE_API_ENDPOINT=
FACE_API_KEY=
HF_TOKEN=
HF_FACE_MODEL_REPO=onnx-community/arcface-onnx
HF_FACE_MODEL_FILE=arcface.onnx
FACE_MATCH_THRESHOLD=0.7
PROCTORING_HIGH_SEVERITY_THRESHOLD=3